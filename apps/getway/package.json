{
  "name": "proxira",
  "version": "0.1.0",
  "description": "轻量化实时请求代理工具，支持本地转发与 Web 面板实时查看请求/响应详情。",
  "type": "module",
  "bin": "dist/cli.js",
  "author": "oceandeep512 <oceandeep512@mail.com>",
  "files": [
    "dist",
    "dashboard-dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "proxira",
    "proxy",
    "api-proxy",
    "request-inspector",
    "debug-tool"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prepare:ui": "node ./scripts/sync-dashboard-dist.mjs",
    "build:pkg": "pnpm --filter @proxira/dashboard build && pnpm run prepare:ui && pnpm run build",
    "pack:pkg": "pnpm run build:pkg && npm pack",
    "start": "node dist/index.js",
    "start:cli": "node dist/cli.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "@proxira/core": "workspace:*",
    "@types/node": "^20.11.17",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
